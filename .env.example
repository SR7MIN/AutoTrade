# Binance USD-M Futures Testnet 凭据：https://testnet.binancefuture.com/
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 程序默认使用 Testnet。主网必须同时显式设置下面的解锁变量。
BINANCE_ENV=testnet
# BINANCE_ALLOW_MAINNET=I_UNDERSTAND

AUTOTRADE_DB=.autotrade/orders.db
AUTOTRADE_RECV_WINDOW_MS=5000
AUTOTRADE_LOG=.autotrade/autotrade.jsonl
AUTOTRADE_LOCK=.autotrade/writer.lock

# Testnet 优先的硬性风控上限。切换主网前必须逐项审核。
AUTOTRADE_MAX_RISK_USDT=25
AUTOTRADE_MAX_RISK_FRACTION=0.01
AUTOTRADE_MAX_ORDER_NOTIONAL=2500
AUTOTRADE_MAX_SYMBOL_NOTIONAL=2500
AUTOTRADE_MAX_TOTAL_NOTIONAL=5000
AUTOTRADE_MAX_LEVERAGE=5
AUTOTRADE_MAX_OPEN_SYMBOLS=3
AUTOTRADE_MAX_DAILY_LOSS=100
AUTOTRADE_MAX_CONSECUTIVE_LOSSES=3
AUTOTRADE_MIN_AVAILABLE_MARGIN=50
AUTOTRADE_MIN_LIQUIDATION_DISTANCE=0.10
AUTOTRADE_FEE_BPS=5
AUTOTRADE_SLIPPAGE_BPS=10
AUTOTRADE_MAX_MARK_AGE_SECONDS=10

# pause：发现无保护受管持仓时锁定开仓。
# close：同时尝试立即 reduce-only 平仓。
AUTOTRADE_UNPROTECTED_ACTION=pause

# 外部 Watchdog。不要把 webhook 密钥提交到代码仓库。
AUTOTRADE_WATCHDOG_INTERVAL_SECONDS=60
AUTOTRADE_WATCHDOG_EXPECTED_ENV=testnet
AUTOTRADE_WATCHDOG_EXPECT_ENTRY_PAUSED=true
# AUTOTRADE_ALERT_WEBHOOK=https://example.invalid/webhook
# AUTOTRADE_ALERT_WEBHOOK_FORMAT=generic
# 支持 feishu：发送飞书文本 webhook 格式。
